# CleanEnroll Environment Configuration - Optimized for Scale
# Copy this to .env and fill in your values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL connection string (Neon or other PostgreSQL provider)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Connection Pool Settings (adjust based on server resources)
# For small server (2GB RAM): DB_POOL_SIZE=10, DB_MAX_OVERFLOW=10
# For medium server (4GB RAM): DB_POOL_SIZE=20, DB_MAX_OVERFLOW=30
# For large server (8GB+ RAM): DB_POOL_SIZE=40, DB_MAX_OVERFLOW=60
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=300

# Query Performance Monitoring
DB_LOG_SLOW_QUERIES=true
DB_SLOW_QUERY_THRESHOLD=1.0  # Log queries slower than 1 second

# ============================================================================
# REDIS CONFIGURATION (Required for rate limiting, caching, and background jobs)
# ============================================================================

# Option 1: Redis URL (Upstash or other managed Redis - RECOMMENDED)
REDIS_URL=rediss://default:password@your-endpoint.upstash.io:6379

# Option 2: Individual Redis settings (self-hosted)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your_password
# REDIS_DB=0
# REDIS_SSL=false

# ============================================================================
# BACKGROUND WORKER CONFIGURATION (ARQ)
# ============================================================================

# Worker concurrency settings (adjust based on server resources)
# For 2GB RAM: ARQ_MAX_JOBS=10
# For 4GB RAM: ARQ_MAX_JOBS=20
# For 8GB RAM: ARQ_MAX_JOBS=40
ARQ_MAX_JOBS=20
ARQ_JOB_TIMEOUT=600  # 10 minutes
ARQ_KEEP_RESULT=3600  # Keep job results for 1 hour

# ============================================================================
# FIREBASE AUTHENTICATION
# ============================================================================

FIREBASE_PROJECT_ID=your-project-id

# ============================================================================
# CLOUDFLARE R2 STORAGE (S3-compatible)
# ============================================================================

R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=cleaningapp

# ============================================================================
# PAYMENT PROCESSING (Dodo Payments)
# ============================================================================

DODO_PAYMENTS_API_KEY=your-api-key
DODO_PAYMENTS_WEBHOOK_SECRET=your-webhook-secret
DODO_PAYMENTS_ENVIRONMENT=test_mode  # or live_mode
DODO_DEFAULT_TAX_CATEGORY=digital_products

# ============================================================================
# SECURITY
# ============================================================================

# Secret key for session management (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here-change-in-production

# CSRF Protection (optional, disabled by default)
CSRF_ENABLED=false

# Security Headers (enabled by default)
SECURITY_HEADERS_ENABLED=true

# Cloudflare Turnstile CAPTCHA (for bot prevention)
TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================

# Resend API (fallback email service)
RESEND_API_KEY=re_...
EMAIL_FROM_ADDRESS=CleanEnroll <noreply@cleanenroll.com>

# Custom SMTP Encryption Key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
SMTP_ENCRYPTION_KEY=your-encryption-key-here

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================

FRONTEND_URL=https://cleanenroll.com

# ============================================================================
# GOOGLE CALENDAR INTEGRATION (Optional)
# ============================================================================

GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://cleanenroll.com/auth/google-calendar

# ============================================================================
# MONITORING & OBSERVABILITY (Optional but recommended for scale)
# ============================================================================

# Sentry for error tracking
# SENTRY_DSN=https://...

# Prometheus metrics endpoint
# ENABLE_METRICS=true

# Application logging level
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================

# Enable response compression
ENABLE_GZIP=true

# API rate limiting (requests per hour per user)
API_RATE_LIMIT_PER_USER=1000

# Maximum request body size (in bytes)
MAX_REQUEST_SIZE=10485760  # 10MB

# ============================================================================
# FEATURE FLAGS (Optional)
# ============================================================================

# Enable/disable features for gradual rollout
ENABLE_CALENDLY_INTEGRATION=true
ENABLE_GOOGLE_CALENDAR_INTEGRATION=true
ENABLE_INVOICE_GENERATION=true
ENABLE_PAYOUT_MANAGEMENT=true

# ============================================================================
# DEVELOPMENT SETTINGS (Remove in production)
# ============================================================================

# Enable debug mode (NEVER use in production)
DEBUG=false

# Enable SQL query logging (NEVER use in production - very verbose)
SQL_ECHO=false
