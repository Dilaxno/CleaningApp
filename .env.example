# Database
DATABASE_URL=postgresql://user:password@localhost:5432/cleanenroll

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id

# R2 Storage (Cloudflare)
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=cleanenroll-storage
R2_PUBLIC_URL=https://your-bucket.r2.dev

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

# Payment (DodoPayments)
DODOPAYMENTS_API_KEY=your-dodopayments-api-key
DODOPAYMENTS_WEBHOOK_SECRET=your-webhook-secret

# Calendly Integration
CALENDLY_CLIENT_ID=your-calendly-client-id
CALENDLY_CLIENT_SECRET=your-calendly-client-secret
CALENDLY_REDIRECT_URI=https://your-domain.com/auth/calendly

# Application
FRONTEND_URL=http://localhost:3000
